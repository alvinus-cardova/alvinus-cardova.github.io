# CCTV PPE Monitoring System - Environment Configuration
# Copy this file to .env and update with your actual values

# Camera Configuration
CAMERA_IP=10.3.8.111
CAMERA_USERNAME=admin
CAMERA_PASSWORD=WOWO@2000

# Email Configuration (for notifications)
EMAIL_USERNAME=admin@company.com
EMAIL_PASSWORD=your_email_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Database Configuration
DATABASE_URL=sqlite:///./cctv_monitoring.db
# For PostgreSQL: postgresql://user:password@localhost/cctv_db

# Server Configuration
HOST=10.4.9.50
PORT=8000
DEBUG=false

# Detection Configuration
MODEL_PATH=models/my_model.pt
CONFIDENCE_THRESHOLD=0.5
DETECTION_INTERVAL=1.0

# Notification Configuration
EMERGENCY_CONTACTS_MEDICAL=["+1234567890", "+1234567891"]
EMERGENCY_CONTACTS_SECURITY=["+1234567892", "+1234567893"]
EMERGENCY_CONTACTS_MANAGEMENT=["+1234567894", "+1234567895"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Storage Configuration
SCREENSHOTS_DIR=data/screenshots
CHARTS_DIR=data/charts
REPORTS_DIR=reports
LOGS_DIR=logs